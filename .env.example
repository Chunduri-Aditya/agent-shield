# Provider API keys used by the current eval harness.
# Copy this file to .env and fill in the values locally.

# Free providers
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
GITHUB_MODELS_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
HF_TOKEN=

# Ollama local OpenAI-compatible endpoint
OPENAI_BASE_URL_OLLAMA=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1:8b

# Local OpenAI-compatible servers
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=local-model
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# OpenAI-compatible free or trial endpoints used by Make targets
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# Kaggle Benchmarks model proxy
# Use through the kaggle-benchmarks SDK/notebook flow; this is not currently
# a plain OpenAI-compatible Inspect endpoint.
MODEL_PROXY_URL=https://mp-staging.kaggle.net/models/openapi
MODEL_PROXY_API_KEY=
LLMS_AVAILABLE=
KAGGLE_MODELS=google/gemini-2.5-flash

# Direct paid providers (optional, leave blank for $0 runs)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
